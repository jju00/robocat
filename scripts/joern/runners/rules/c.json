{
  "language": "c",
  "joern_import": "c",
  "function_parser": "c",
  "trace_support": null,
  "dynamic_trace_type": null,
  "sources": [
    {
      "name": "argv",
      "type": "identifier_regex",
      "value": ".*\\bargv\\b.*"
    },
    {
      "name": "env_input",
      "type": "call_regex",
      "value": "(getenv)"
    },
    {
      "name": "stdin_input",
      "type": "call_regex",
      "value": "(scanf|fscanf|sscanf|fgets|gets|getchar|read|recv)"
    }
  ],
  "sinks": {
    "command": {
      "regex": "(system|execl|execlp|execle|execv|execvp|execve|popen)"
    },
    "memory": {
      "regex": "(strcpy|strcat|sprintf|vsprintf|gets|memcpy)"
    },
    "format": {
      "regex": "(printf|fprintf|sprintf|snprintf|syslog)"
    },
    "file": {
      "regex": "(fopen|open|freopen)"
    }
  },
  "sanitizers": [
    "fgets",
    "snprintf",
    "strncpy",
    "strlcpy",
    "strlcat",
    "memchr",
    "memcmp",
    "strncmp",
    "strchr",
    "strstr",
    "isalpha",
    "isdigit",
    "isalnum",
    "isspace",
    "toupper",
    "tolower",
    "buffer_eq_icase_ss",
    "buffer_eq_icase_ssn",
    "http_request_field_check_value",
    "http_header_str_contains_token",
    "http_header_hkey_get",
    "http_header_str_to_code",
    "li_restricted_strtoint64"
  ],
  "sink_priority_weight": {
    "command": 1.0,
    "memory": 0.95,
    "format": 0.75,
    "file": 0.7
  }
}
